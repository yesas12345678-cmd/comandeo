datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique // El subdominio para la URL (ej: "barpaco")
  apiKey        String     @unique @default(uuid()) // Token secreto para el agente de impresión
  adminUsername String     @default("admin")
  adminPassword String     @default("admin123")
  createdAt     DateTime   @default(now())
  categories    Category[]
  products      Product[]
  tables        Table[]
  orders        Order[]
  printJobs     PrintJob[]
  waiters       Waiter[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name]) // El nombre de categoría es único dentro de cada bar
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum TableStatus {
  FREE
  BUSY
}

model Table {
  id       String      @id @default(uuid())
  number   Int
  status   TableStatus @default(FREE)
  orders   Order[]
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, number]) // El número de mesa es único dentro de cada bar
}

model Waiter {
  id       String  @id @default(uuid())
  name     String
  pin      String  // Código PIN de acceso rápido (ej: "1234")
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@unique([tenantId, pin]) // El PIN es único por restaurante
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
}

model Order {
  id            String         @id @default(uuid())
  tableId       String
  table         Table          @relation(fields: [tableId], references: [id])
  items         Json
  total         Float
  status        OrderStatus    @default(PENDING)
  paymentMethod PaymentMethod?
  createdAt     DateTime       @default(now())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  waiterId      String?
  waiter        Waiter?        @relation(fields: [waiterId], references: [id], onDelete: SetNull)
}

enum PrintJobType {
  KITCHEN  // Ticket para cocina (solo productos y cantidad)
  RECEIPT  // Factura simplificada de caja (con precios, subtotal y total)
}

model PrintJob {
  id        String       @id @default(uuid())
  tableNum  Int
  items     Json
  total     Float
  printed   Boolean      @default(false)
  type      PrintJobType @default(KITCHEN)
  createdAt DateTime     @default(now())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
